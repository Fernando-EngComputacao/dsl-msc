{
  "name": "dsl",
  "scopeName": "source.dsl",
  "fileTypes": [
    ".dsl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.dsl",
      "match": "\\b(aplicar|comando|cultura|fungicida|herbicida|inseticida|nao_misturar|proibido|usando)\\b|\\b(informar:|regra:|regra_clima:|regra_global:|regra_varredura:)\\B"
    },
    {
      "name": "string.quoted.double.dsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    },
    {
      "name": "string.quoted.single.dsl",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.dsl",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.dsl"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.dsl"
            }
          }
        },
        {
          "begin": "//",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.dsl"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.dsl"
        }
      ]
    },
    "string-character-escape": {
      "name": "constant.character.escape.dsl",
      "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
    }
  }
}
