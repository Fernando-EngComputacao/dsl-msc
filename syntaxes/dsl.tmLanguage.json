{
  "name": "dsl",
  "scopeName": "source.dsl",
  "fileTypes": [
    ".dsl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.dsl",
      "match": "\\b(clean_panels|clouds|command|dirt_level|do|drone|energy_limit|farm|fire|fog|ignore_and_continue|on_sensor_input|return_to_base|scan|send_5G_alert|smoke_detected|storm|to_current_farm|urgency_high|using|weather|with_photo)\\b"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.dsl",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.dsl"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.dsl"
            }
          }
        },
        {
          "begin": "//",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.dsl"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.dsl"
        }
      ]
    }
  }
}
